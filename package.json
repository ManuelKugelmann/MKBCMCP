import { FastMCP } from "fastmcp";
import { z } from "zod";
import { createOctokit } from "../lib/octokit.js";
import { renderClaudeMd, renderReadme, renderGitignore, renderDecisions } from "../lib/templates.js";

export function registerBootstrapTools(server: FastMCP) {
  server.addTool({
    name: "gh_project_bootstrap",
    description:
      "Create a GitHub repo with structured CLAUDE.md for chat-to-code handoff. " +
      "Generates CLAUDE.md, README, .gitignore, and decisions doc in a single atomic commit.",
    parameters: z.object({
      name: z.string().describe("Repo name (slug)"),
      description: z.string().describe("One-line repo description"),
      project_context: z.string().describe("Project background, decisions from chat"),
      tech_stack: z.array(z.string()).describe('e.g. ["typescript", "unity"]'),
      goals: z.array(z.string()).describe("Immediate goals for Claude Code"),
      constraints: z.array(z.string()).optional().describe("Known constraints, non-goals"),
      references: z.array(z.string()).optional().describe("URLs, papers, docs"),
      template: z
        .enum(["node-ts", "unity-cs", "python", "bare"])
        .optional()
        .default("bare")
        .describe("Project template"),
      private: z.boolean().optional().default(true),
      topics: z.array(z.string()).optional(),
    }),
    execute: async (args, { session }) => {
      const octokit = createOctokit(session);

      // 1. Create repo
      const { data: repo } = await octokit.rest.repos.createForAuthenticatedUser({
        name: args.name,
        description: args.description,
        private: args.private,
        auto_init: false,
      });

      // 2. Set topics if provided
      if (args.topics?.length) {
        await octokit.rest.repos.replaceAllTopics({
          owner: repo.owner.login,
          repo: repo.name,
          names: args.topics,
        });
      }

      // 3. Build file tree
      const files: Array<{ path: string; content: string }> = [
        { path: "CLAUDE.md", content: renderClaudeMd(args, repo.owner.login) },
        { path: "README.md", content: renderReadme(args) },
        { path: ".gitignore", content: renderGitignore(args.template ?? "bare") },
        { path: "docs/decisions.md", content: renderDecisions(args) },
        { path: ".github/copilot-instructions.md", content: renderClaudeMd(args, repo.owner.login) },
      ];

      // 4. Atomic multi-file commit via Git Data API
      const blobs = await Promise.all(
        files.map((f) =>
          octokit.rest.git
            .createBlob({
              owner: repo.owner.login,
              repo: repo.name,
              content: Buffer.from(f.content).toString("base64"),
              encoding: "base64",
            })
            .then((r) => ({ path: f.path, sha: r.data.sha }))
        )
      );

      const { data: tree } = await octokit.rest.git.createTree({
        owner: repo.owner.login,
        repo: repo.name,
        tree: blobs.map((b) => ({
          path: b.path,
          mode: "100644" as const,
          type: "blob" as const,
          sha: b.sha,
        })),
      });

      const { data: commit } = await octokit.rest.git.createCommit({
        owner: repo.owner.login,
        repo: repo.name,
        message: "Initial project bootstrap via mkbc-mcp",
        tree: tree.sha,
      });

      const { data: ref } = await octokit.rest.git.createRef({
        owner: repo.owner.login,
        repo: repo.name,
        ref: "refs/heads/main",
        sha: commit.sha,
      });

      // 5. Set default branch
      await octokit.rest.repos.update({
        owner: repo.owner.login,
        repo: repo.name,
        default_branch: "main",
      });

      return `✅ Created ${repo.html_url}\n📄 Files: ${files.map((f) => f.path).join(", ")}\n🔀 Branch: main (${commit.sha.slice(0, 7)})`;
    },
  });

  server.addTool({
    name: "gh_project_add_context",
    description:
      "Append content to a specific section of an existing CLAUDE.md in a repo. " +
      "Sections: goals, constraints, decisions, context, references.",
    parameters: z.object({
      repo: z.string().describe("owner/name"),
      section: z.enum(["goals", "constraints", "decisions", "context", "references"]),
      content: z.string().describe("Markdown content to append"),
    }),
    execute: async (args, { session }) => {
      const octokit = createOctokit(session);
      const [owner, repo] = args.repo.split("/");

      // Read current CLAUDE.md
      const { data: file } = await octokit.rest.repos.getContent({
        owner,
        repo,
        path: "CLAUDE.md",
      });

      if (!("content" in file)) throw new Error("CLAUDE.md is not a file");

      const currentContent = Buffer.from(file.content, "base64").toString("utf-8");

      // Map section enum to header
      const sectionHeaders: Record<string, string> = {
        goals: "## Goals",
        constraints: "## Constraints",
        decisions: "## Decisions",
        context: "## Project Context",
        references: "## References",
      };

      const header = sectionHeaders[args.section];
      const headerIndex = currentContent.indexOf(header);
      if (headerIndex === -1) throw new Error(`Section "${header}" not found in CLAUDE.md`);

      // Find end of section (next ## or EOF)
      const afterHeader = currentContent.indexOf("\n", headerIndex);
      const nextSection = currentContent.indexOf("\n## ", afterHeader + 1);
      const insertPos = nextSection === -1 ? currentContent.length : nextSection;

      const updated =
        currentContent.slice(0, insertPos).trimEnd() +
        "\n" +
        args.content.trim() +
        "\n" +
        (nextSection === -1 ? "" : "\n" + currentContent.slice(nextSection));

      // Write back with sha
      await octokit.rest.repos.createOrUpdateFileContents({
        owner,
        repo,
        path: "CLAUDE.md",
        message: `Update CLAUDE.md: add to ${args.section}`,
        content: Buffer.from(updated).toString("base64"),
        sha: file.sha,
      });

      return `✅ Appended to ${header} in ${args.repo}/CLAUDE.md`;
    },
  });
}
