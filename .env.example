# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers -> New OAuth App
# Callback URL: https://your-host.uber.space/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public URL where the server is reachable
BASE_URL=https://your-host.uber.space

# Server port (must match uberspace web backend config)
PORT=62100

# Data directory for oauth tokens, clone cache, and file store
MCP_DATA_DIR=/home/$USER/mcp-data
